<?xml version="1.0" encoding="utf-8"?>
<!-- Plantilla segura: no incluir credenciales reales en Git. -->
<configuration>
  <connectionStrings>
    <add name="ERP_DB"
         connectionString="Server=${DB_HOST};Database=${DB_NAME};User Id=${DB_USER};Password=${DB_PASSWORD};Encrypt=True;TrustServerCertificate=False;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="SMTP_HOST" value="${SMTP_HOST}" />
    <add key="SMTP_PORT" value="${SMTP_PORT}" />
    <add key="SMTP_USER" value="${SMTP_USER}" />
    <add key="SMTP_PASSWORD" value="${SMTP_PASSWORD}" />
  </appSettings>
</configuration>
